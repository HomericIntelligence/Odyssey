# Lychee link checker ignore patterns
# https://github.com/lycheeverse/lychee

# Ignore file:// URLs (local file system references)
file:///

# Ignore example/placeholder URLs
example\.com
example\.org

# Ignore template files with placeholder URLs
\.claude/skills/.*/templates/.*
agents/templates/.*
# Specific placeholder URLs in templates
https://github.com/org/repo/issues/XX

# Ignore old repository name redirects (mvillmow -> HomericIntelligence)
# These are valid redirects, not broken links
github\.com/HomericIntelligence/ProjectOdyssey

# Ignore ProjectMnemosyne skill links — GitHub returns intermittent 404s to
# unauthenticated lychee on org repos even when the file exists (verified via
# `gh api repos/HomericIntelligence/ProjectMnemosyne/contents/skills/...`).
github\.com/HomericIntelligence/ProjectMnemosyne

# Ignore pytorch docs redirects (pytorch.org -> docs.pytorch.org)
pytorch\.org/docs

# Ignore Claude URLs that return 403 to bots (valid URLs, bot-protection blocks lychee)
claude\.ai
platform\.claude\.com
code\.claude\.com

# Ignore external sites that may be intermittently unavailable
softjourn\.com
coderower\.com
pullchecklist\.com
geeksforgeeks\.org
conventionalcommits\.org
contributor-covenant\.org
# cppreference returns 403 to lychee's user-agent (bot protection); pages
# resolve fine in browsers
en\.cppreference\.com

# Ignore root-relative links (lychee cannot resolve these without --root-url)
# These are valid repo-relative paths in CLAUDE.md, docs/adr/, notebooks/README.md
^/CLAUDE\.md$
^/\.claude/
^/agents/
^/docs/
^/examples/
