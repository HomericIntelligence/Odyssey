# Lychee link checker ignore patterns
# https://github.com/lycheeverse/lychee

# Ignore file:// URLs (local file system references)
file:///

# Ignore example/placeholder URLs
example\.com
example\.org

# Ignore template files with placeholder URLs
\.claude/skills/.*/templates/.*
agents/templates/.*
# Specific placeholder URLs in templates
https://github.com/org/repo/issues/XX

# Ignore old repository name redirects (mvillmow -> HomericIntelligence)
# These are valid redirects, not broken links
github\.com/HomericIntelligence/ProjectOdyssey

# Ignore pytorch docs redirects (pytorch.org -> docs.pytorch.org)
pytorch\.org/docs

# Ignore root-relative links (lychee cannot resolve these without --root-url)
# These are valid repo-relative paths in CLAUDE.md, docs/adr/, notebooks/README.md
^/CLAUDE\.md$
^/\.claude/
^/agents/
^/docs/
^/examples/
