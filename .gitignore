# uv-managed virtual environment + caches (ADR-018)
.venv/
.uv-cache/
# Legacy pixi env dirs (kept ignored in case a stale checkout still has them)
.pixi/

# Python cache directories
__pycache__
*.pyc

# Python wheel build artifacts (produced by `just wheel`)
*.egg-info/
python/build/

# agentic build artifacts
logs/
build/
worktrees/
dist/
site/
/datasets/

# MkDocs build artifacts
site/
.cache/

# Mojo build artifacts
*.o
*.a
*.mojopkg
train
examples/*/train
examples/*/inference
test_*
!tests/**
!conda.recipe/test_*
# `test_*` above targets compiled Mojo test BINARIES, but also matches `.mojo`
# sources; rescue example test sources so they can be tracked + run in CI
# (e.g. examples/*/test_backward.mojo, test_bn_persistence.mojo).
!examples/**/test_*.mojo
.worktrees/
.claude/worktrees/
.claude/scheduled_tasks.lock
.issue_implementer/

# Training artifacts
*.log
training_*.txt
*_weights/
checkpoints/

# Environment files (never commit secrets)
.env
.env.*
!.env.example

# Editor files
*.swp
.coverage
/test_cumulative.mojo
lenet5_weights_autograd/
.claude-prompt-*.md
__pycache__/
