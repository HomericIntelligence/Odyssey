*.o
*.a
*.mojopkg
train
examples/*/train
examples/*/inference
test_*
!tests/**
!conda.recipe/test_*
.worktrees/
.claude/worktrees/
.claude/scheduled_tasks.lock
.issue_implementer/

# Training artifacts
*.log
training_*.txt
*_weights/
checkpoints/

# Environment files (never commit secrets)
.env
.env.*
!.env.example

# Editor files
*.swp
.coverage
/test_cumulative.mojo
